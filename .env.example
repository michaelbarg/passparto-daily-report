# ─── Required ───────────────────────────────────────────────
KLAVIYO_KEY=pk_...
ANTHROPIC_API_KEY=sk-ant-...
MICHAEL_EMAIL=michael@passparto.com

# ─── Shopify (preferred — live store data for unfulfilled orders) ──
# Create a Custom App in Shopify admin (Settings > Apps and sales
# channels > Develop apps > Create an app), grant `read_orders` and
# `read_customers` scopes, install it, and paste the Admin API access
# token below.
SHOPIFY_STORE_DOMAIN=passparto.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_...
# Optional override:
# SHOPIFY_API_VERSION=2024-10

# ─── Optional Klaviyo overrides ─────────────────────────────
# KLAVIYO_PLACED_ORDER_METRIC_ID=
# KLAVIYO_FULFILLED_ORDER_METRIC_ID=

# ─── Tuning ─────────────────────────────────────────────────
# UNFULFILLED_LOOKBACK_DAYS=14
# UNFULFILLED_MAX_IN_EMAIL=50
